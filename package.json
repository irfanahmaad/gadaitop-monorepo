{
  "name": "gadaitop-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:api": "turbo build --filter=api",
    "build:web": "turbo build --filter=web",
    "build:marketing": "turbo build --filter=marketing",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api",
    "dev:marketing": "turbo dev --filter=marketing",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test:e2e": ".venv/bin/python apps/web/e2e/super-admin/test_super_admin_full.py",
    "test:e2e:python3": "python3 apps/web/e2e/super-admin/test_super_admin_full.py",
    "test:e2e:super-admin": ".venv/bin/python apps/web/e2e/super-admin/test_super_admin_full.py",
    "test:e2e:spk-nkb": ".venv/bin/python apps/web/e2e/spk-nkb-flow/spk-nkb-flow_test_full.py",
    "test:e2e:spk-nkb:headed": "HEADED=1 .venv/bin/python apps/web/e2e/spk-nkb-flow/spk-nkb-flow_test_full.py",
    "test:e2e:spk-nkb:slow": "HEADED=1 SLOW=500 .venv/bin/python apps/web/e2e/spk-nkb-flow/spk-nkb-flow_test_full.py",
    "test:e2e:headed": "HEADED=1 .venv/bin/python apps/web/e2e/super-admin/test_super_admin_full.py",
    "test:e2e:slow": "HEADED=1 SLOW=500 .venv/bin/python apps/web/e2e/super-admin/test_super_admin_full.py",
    "test:e2e:setup": ".venv/bin/pip install -r apps/web/e2e/requirements.txt && .venv/bin/playwright install chromium",
    "test:e2e:setup:python3": "pip3 install -r apps/web/e2e/requirements.txt && playwright install chromium"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.5.5",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  }
}
