{
  "name": "gadaitop-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:api": "turbo build --filter=api",
    "build:web": "turbo build --filter=web",
    "build:marketing": "turbo build --filter=marketing",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api",
    "dev:marketing": "turbo dev --filter=marketing",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:ui": "pnpm --filter web test:e2e:ui",
    "test:e2e:headed": "pnpm --filter web test:e2e:headed",
    "test:e2e:report": "pnpm --filter web test:e2e:report",
    "test:e2e:super-admin": "pnpm --filter web test:e2e -- --grep \"Super Admin|Dashboard|Management|PT —|Tipe Barang\"",
    "test:e2e:super-admin:headed": "pnpm --filter web test:e2e:headed -- --grep \"Super Admin|Dashboard|Management|PT —|Tipe Barang\"",
    "test:e2e:spk-nkb": "pnpm --filter web test:e2e -- --grep \"SPK|Customer Portal|NKB\"",
    "test:e2e:spk-nkb:headed": "pnpm --filter web test:e2e:headed -- --grep \"SPK|Customer Portal|NKB\""
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.5.5",
    "typescript": "5.7.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  }
}
